<Window x:Class="CyberSecuritybot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chatbot"
        Height="450"
        Width="800"
        Background="Black">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="CYBERSECURITY AWARENESS CHATBOT"
                   Foreground="Lime"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,10"/>

        <!-- CHAT AREA -->
        <RichTextBox x:Name="rtbChat"
                     Grid.Row="1"
                     Margin="0,20,0,20"
                     IsReadOnly="True"
                     Background="#111111"
                     Foreground="White"/>

        <!-- INPUT AREA -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal">

            <TextBox x:Name="txtMessage"
                     Width="650"
                     Height="35"
                     FontSize="16"
                     Margin="0,0,10,0"/>

            <Button Content="Send"
                    Width="100"
                    Height="35"
                    Background="Lime"
                    Foreground="Black"
                    FontWeight="Bold"
                    Click="BtnSend_Click"/>
        </StackPanel>

    </Grid>
</Window>